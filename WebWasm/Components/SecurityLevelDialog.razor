@using WebWasm.Models

<ModalShell IsOpen="IsOpen" OnClose="CloseModal">
	<div class="modal-header">
		<h2>Security Level</h2>
		<button class="btn-close" @onclick="CloseModal">×</button>
	</div>

	<div class="modal-body">
		<p class="entity-label">@EntityLabel</p>

		<div class="form-group">
			<label>Security Level *</label>
			<select class="form-control" @bind="_selectedLevel">
				@foreach (var level in _levels)
				{
					<option value="@level">@level</option>
				}
			</select>
		</div>

		<div class="form-section">
			<h3>What this means</h3>
			<p class="level-description">@GetDescription(_selectedLevel)</p>
		</div>

		@if (_selectedLevel != CurrentLevel)
		{
			<div class="form-section form-section-warn">
				<p>Current level is <strong>@CurrentLevel</strong>. Saving will change it to <strong>@_selectedLevel</strong>.</p>
			</div>
		}

		@if (!string.IsNullOrEmpty(_errorMessage))
		{
			<div class="error-message">
				⚠ @_errorMessage
			</div>
		}
	</div>

	<div class="modal-footer">
		<button class="btn-secondary" @onclick="CloseModal">Cancel</button>
		<button class="btn-primary" @onclick="HandleSubmit" disabled="@(_selectedLevel == CurrentLevel)">Save</button>
	</div>
</ModalShell>
